# HTTP server
PORT=3000
NODE_ENV=production
CLOUD_MODE=false
API_KEY=replace-with-a-long-random-api-key
DEVICE_TIMEZONE=Asia/Manila
EMERGENCY_ATTENDANCE_PASSWORD=replace-with-a-strong-emergency-password

# Optional named dashboard accounts. Omit roles you do not need.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password
HR_USERNAME=hr
HR_PASSWORD=replace-with-a-strong-hr-password
VIEWER_USERNAME=viewer
VIEWER_PASSWORD=replace-with-a-strong-viewer-password

# Optional employee dashboard accounts. Prefer managing these from /accounts.
# Format: username|password|employeeId, separated by commas.
EMPLOYEE_ACCOUNTS=

# Optional per-reader keys: DEVICE-ID:key,DEVICE-ID-2:key
DEVICE_API_KEYS=ATTENDANCE-DEVICE-01:replace-with-a-unique-device-key

# Browser/API protection
ALLOWED_ORIGINS=http://localhost:3000
REQUESTS_PER_MINUTE=300
AUTH_ATTEMPTS_PER_15_MINUTES=10
SESSION_TTL_HOURS=12
TRUST_PROXY=false
ENABLE_TEST_ENDPOINTS=false

# Attendance behavior
DUPLICATE_SECONDS=180
DEVICE_DISPLAY_MS=3000
UNRECORDED_LOG_RETENTION_HOURS=24
MAX_UNRECORDED_ATTENDANCE_LOGS=50

# PostgreSQL primary. Leave DATABASE_URL and PGHOST blank for local JSON/SQLite mode.
# DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/gms_attendance
# PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=gms_attendance
PGUSER=postgres
PGPASSWORD=
PGSSL=false
PG_CONNECT_TIMEOUT_MS=3000

# Supabase Storage for employee profile pictures (optional).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_EMPLOYEE_PHOTOS_BUCKET=employee-photos

# Social sign-in (callback: APP_BASE_URL/api/auth/oauth/{google|facebook}/callback)
APP_BASE_URL=http://localhost:3000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=

# SQLite synchronized local backup
SQLITE_BACKUP_ENABLED=true
SQLITE_SYNC_DELAY_MS=1500
PYTHON_COMMAND=python
