# HTTP server
PORT=3000
NODE_ENV=production
CLOUD_MODE=false
API_KEY=replace-with-a-long-random-api-key
DEVICE_TIMEZONE=Asia/Manila
EMERGENCY_ATTENDANCE_PASSWORD=replace-with-a-strong-emergency-password

# Optional named dashboard accounts. Omit roles you do not need.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password
HR_USERNAME=hr
HR_PASSWORD=replace-with-a-strong-hr-password
VIEWER_USERNAME=viewer
VIEWER_PASSWORD=replace-with-a-strong-viewer-password

# Optional per-reader keys: DEVICE-ID:key,DEVICE-ID-2:key
# The global API_KEY remains a migration fallback for already-flashed readers.
DEVICE_API_KEYS=ATTENDANCE-DEVICE-01:replace-with-a-unique-device-key

# Browser/API protection
ALLOWED_ORIGINS=http://localhost:3000
REQUESTS_PER_MINUTE=300
AUTH_ATTEMPTS_PER_15_MINUTES=10
SESSION_TTL_HOURS=12
TRUST_PROXY=false
ENABLE_TEST_ENDPOINTS=false

# PostgreSQL primary. Set DATABASE_URL, or use the PG* variables below.
# DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/gms_attendance
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=gms_attendance
PGUSER=postgres
PGPASSWORD=replace-with-your-postgres-password
PGSSL=false
PG_CONNECT_TIMEOUT_MS=3000

# SQLite synchronized fallback/backup
SQLITE_BACKUP_ENABLED=true
SQLITE_SYNC_DELAY_MS=1500
PYTHON_COMMAND=python
